# ============================================================================
# PromptHub Docker 部署环境变量示例
#
# 使用方法：
#   cp .env.docker.example .env.docker
#   修改下面的值（尤其是密码和 JWT_SECRET）
#   docker compose --env-file .env.docker up -d --build
# ============================================================================

# ---------- MySQL 配置 ----------
MYSQL_ROOT_PASSWORD=root123456
MYSQL_DATABASE=prompt_hub
MYSQL_USER=prompthub
MYSQL_PASSWORD=prompthub123
# 宿主机映射端口（避免与本机 MySQL 冲突时修改）
MYSQL_PORT=3306

# ---------- 应用配置 ----------
# 宿主机访问端口
APP_PORT=3000

# JWT 密钥（生产环境务必修改为随机长字符串！）
# 可用: openssl rand -base64 48 生成
JWT_SECRET=please-change-this-jwt-secret-in-production

# JWT 过期时间
JWT_EXPIRES_IN=7d

# 是否在首次启动时执行 seed（注入默认管理员与示例 prompt）
# 首次启动后可改为 false 加快启动
RUN_SEED=true

# ---------- OAuth 第三方登录配置 ----------
# OAuth 回调基础 URL（必须是 provider 后台配置的授权回调地址的根域名）
# 本地开发：http://localhost:3000
# 生产部署：https://your-domain.com
OAUTH_CALLBACK_BASE_URL=http://localhost:3000

# GitHub OAuth App
# 申请地址：https://github.com/settings/developers → New OAuth App
# Authorization callback URL 填：${OAUTH_CALLBACK_BASE_URL}/api/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
